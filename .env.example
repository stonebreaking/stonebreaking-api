# ═══════════════════════════════════════════════════════════
# StoneBreaking Backend — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ============================================
# SERVER
# ============================================
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://stonebreaking:yourpassword@localhost:5432/stonebreaking

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT
# ============================================
JWT_SECRET=change-this-to-a-64-char-random-string
JWT_EXPIRY=7d

# ============================================
# AI MODEL API KEYS
# ============================================
# ── PRIMARY: OpenAI Compatible (REQUIRED) ───────────────
# This is the main provider. Supports OpenAI, DeepSeek,
# Together AI, Groq, any OpenAI-compatible endpoint.
OPENAI_API_KEY=sk-your-openai-key
# Optional: Override base URL for non-OpenAI providers
# Examples:
#   DeepSeek:    https://api.deepseek.com/v1
#   Together:    https://api.together.xyz/v1
#   Groq:        https://api.groq.com/openai/v1
#   Local/Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# ── SECONDARY: DeepSeek (cost-effective) ────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ── FAILBACK: Other providers ──────────────────────────
KIMI_API_KEY=sk-your-kimi-key
ANTHROPIC_API_KEY=sk-ant-your-key
GOOGLE_AI_API_KEY=your-google-key

# ============================================
# MODEL SELECTION
# ============================================
# Default model for most queries (cost-effective)
DEFAULT_MODEL=gpt4o_mini
# Cheapest model for simple queries & cost optimization
CHEAP_MODEL=gpt4o_mini
# Premium model for complex queries (Obliterate tier only)
PREMIUM_MODEL=gpt4o_pro
# Model for companion system
COMPANION_MODEL=gpt4o_mini

# ============================================
# COST CONTROL (CRITICAL — PREVENTS LOSSES)
# ============================================
# Maximum platform-wide AI spend per day (USD)
DAILY_SPEND_CAP_USD=50

# Maximum platform-wide AI spend per hour (USD)
HOURLY_SPEND_CAP_USD=10

# Maximum cost per single request (USD)
MAX_PER_REQUEST_COST_USD=0.05

# Auto-downgrade to cheapest model when daily spend > this % of cap
DOWNGRADE_THRESHOLD_PCT=80

# Emergency kill switch — if true, all AI requests are rejected
EMERGENCY_KILL_SWITCH=false

# ============================================
# USAGE LIMITS BY TIER
# ============================================
BREAKER_DAILY_MSGS=30
BREAKER_DAILY_IMAGES=5
BREAKER_MAX_INPUT_TOKENS=4000

SHATTER_DAILY_MSGS=80
SHATTER_DAILY_IMAGES=15
SHATTER_MAX_INPUT_TOKENS=8000

OBLITERATE_DAILY_MSGS=200
OBLITERATE_DAILY_IMAGES=40
OBLITERATE_MAX_INPUT_TOKENS=16000

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# ============================================
# COMPANION SYSTEM
# ============================================
COMPANION_FREE_DAILY_MSGS=30
COMPANION_ELITE_DAILY_MSGS=100
COMPANION_ELITE_PRO_DAILY_MSGS=300
